# ⚠️  이 파일을 복사해서 db-secret.yaml을 만드세요.
# db-secret.yaml은 절대 Git에 커밋하지 마세요.
#
# 운영 환경에서는 AWS Secrets Manager + External Secrets Operator 사용을 권장합니다.
#
# 사용법:
#   cp k8s/db-secret.yaml.example k8s/db-secret.yaml
#   # db-secret.yaml 안의 값을 실제 비밀번호로 변경 후 적용
#   kubectl apply -f k8s/db-secret.yaml

apiVersion: v1
kind: Secret
metadata:
  name: galaga-db-secret
  namespace: galaga
type: Opaque
stringData:
  DB_HOST: galaga-mysql
  DB_PORT: "3306"
  DB_USER: galaga
  DB_PASSWORD: CHANGE_ME
  DB_NAME: galaga_db
  MYSQL_ROOT_PASSWORD: CHANGE_ME
  MYSQL_DATABASE: galaga_db
  MYSQL_USER: galaga
  MYSQL_PASSWORD: CHANGE_ME
